{
  "name": "drawtoask",
  "productName": "Draw to Ask",
  "version": "0.1.3",
  "description": "Hotkey → screen freezes → circle anything → get an answer as a sticky note.",
  "main": "src/main/main.js",
  "bin": {
    "drawtoask": "bin/drawtoask.js"
  },
  "files": [
    "src/",
    "bin/"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "electron",
    "screenshot",
    "annotation",
    "ai",
    "vision",
    "productivity"
  ],
  "scripts": {
    "start": "electron .",
    "spike": "electron . --spike",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win"
  },
  "dependencies": {
    "electron": "^35.0.0"
  },
  "devDependencies": {
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.drawtoask.app",
    "mac": {
      "category": "public.app-category.productivity",
      "extendInfo": {
        "NSScreenCaptureUsageDescription": "Draw to Ask captures the screen so you can circle a region and ask a question about it."
      }
    },
    "win": {
      "target": "nsis"
    }
  }
}
